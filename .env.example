DISCORD_TOKEN=put-your-bot-token-here

# Optional. Slash commands update instantly for one guild while developing.
# Leave blank for global commands, which can take longer to appear.
DISCORD_GUILD_ID=

# Optional defaults. You can also set these inside Discord with /threat config.
DEFAULT_MOD_ROLE_ID=
DEFAULT_ALERT_CHANNEL_ID=
DEFAULT_ALERT_THRESHOLD=80

# SQLite file path. Relative paths are resolved from the project folder.
DATABASE_PATH=data/threats.sqlite3
